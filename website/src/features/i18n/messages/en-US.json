{
  "settings": {
    "locale": "en-US",
    "direction": "ltr"
  },
  "components": {
    "images": {
      "logo-image": {
        "url": "https://ik.imagekit.io/alramadi/alphavork/template/logo.png",
        "alternate": "Alphavork Logo"
      },
      "placeholder-image": {
        "url": "https://ik.imagekit.io/alramadi/alphavork/template/placeholder.png",
        "alternate": "Placeholder"
      },
      "not-found-image": {
        "url": "https://ik.imagekit.io/alramadi/alphavork/template/not-found.png",
        "alternate": "Not Found"
      }
    },
    "fields": {
      "inputs": {
        "phone-number": {
          "country": {
            "default-country-value": {
              "iso": "us",
              "country-code": "1"
            },
            "placeholder": "Search by (e.g. county name, code or iso)",
            "no-match": "No matching countries found "
          }
        }
      },
      "selects": {},
      "file-upload": {
        "title": "Drag & drop file here",
        "help": "Or you could <trigger>chose a file</trigger> to upload",
        "alerts": {
          "error": "Something went wrong while uploading file. Please try again."
        }
      }
    },
    "languages": {
      "data": {
        "default-country": {
          "direction": "ltr",
          "locale": "en-US",
          "flag": "🇺🇸",
          "label": "English (United States)"
        }
      },
      "ui": {
        "placeholder": "Search your language...",
        "when-no-match": "No matching languages found"
      }
    }
  },
  "app": {
    "layout": {
      "metadata": {
        "title": {
          "default": "Alphavork Template",
          "template": "%s | Alphavork Template"
        },
        "description": "A comprehensive SaaS boilerplate built with Next.js and .NET Web API, providing everything you need to launch your software-as-a-service product quickly and efficiently.",
        "icons": {
          "icon": [
            {
              "sizes": "16x16",
              "type": "image/png",
              "url": "https://ik.imagekit.io/alramadi/alphavork/template/icons/favicon-16x16.png"
            },
            {
              "sizes": "32x32",
              "type": "image/png",
              "url": "https://ik.imagekit.io/alramadi/alphavork/template/icons/favicon-32x32.png"
            },
            {
              "sizes": "192x192",
              "type": "image/png",
              "url": "https://ik.imagekit.io/alramadi/alphavork/template/icons/android-chrome-192x192.png"
            },
            {
              "type": "image/png",
              "sizes": "512x512",
              "url": "https://ik.imagekit.io/alramadi/alphavork/template/icons/android-chrome-512x512.png"
            }
          ],
          "apple": "https://ik.imagekit.io/alramadi/alphavork/template/icons/apple-touch-icon.png",
          "shortcut": "https://ik.imagekit.io/alramadi/alphavork/template/icons/favicon.ico"
        },
        "authors": [
          {
            "name": "Nawaf Alramadi",
            "url": "https://www.alramadi.me"
          }
        ],
        "creator": "Alphavork"
      },
      "header": {
        "navigation-menu-groups": [
          {
            "label": "App",
            "links": [
              {
                "url": "/",
                "label": "Home",
                "description": "Go to homepage — your starting point for everything"
              },
              {
                "url": "/about",
                "label": "About",
                "description": "Learn about who we are, what we believe, and where we're headed"
              },
              {
                "url": "/contact",
                "label": "Contact",
                "description": "Connect with our team for support, feedback, or general inquiries"
              }
            ]
          },
          {
            "label": "Components",
            "links": []
          }
        ]
      },
      "footer": {
        "copyrights": "© 2026 Alphavork Template. All rights reserved.",
        "links": [
          {
            "url": "https://github.com/nawaf-alramadi/alphavork-template",
            "label": "GITHUB"
          }
        ]
      }
    },
    "not-found": {
      "subtitle": "Whoops!",
      "title": "Something went wrong",
      "description": " The page you're looking for isn't found, we suggest you back to home.",
      "go-back-to-home": {
        "url": "/",
        "label": "Go back to home"
      }
    },
    "components": {
      "layout": {},
      "page": {}
    }
  }
}
