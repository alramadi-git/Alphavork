      "authentication": {
        "register": {
          "page": {
            "metadata": {
              "title": "Register"
            },
            "form": {
              "avatar": {
                "label": "Avatar"
              },
              "location": {
                "country": {
                  "label": "Country",
                  "placeholder": "Enter country (e.g., United States, etc...)"
                },
                "city": {
                  "label": "City",
                  "placeholder": "Enter city (e.g., New York, etc...)"
                },
                "street": {
                  "label": "Street",
                  "placeholder": "Enter street (e.g., 5th Avenue, etc...)"
                },
                "latitude": {
                  "label": "Latitude",
                  "placeholder": "Enter latitude (e.g., 40.7745062, etc...)"
                },
                "longitude": {
                  "label": "Longitude",
                  "placeholder": "Enter longitude (e.g., -73.9655418, etc...)"
                }
              },
              "username": {
                "label": "Username",
                "placeholder": "Enter username (e.g, nawaf alramadi, etc...)"
              },
              "birthday": {
                "label": "Birthday",
                "placeholder": "Enter birthday (e.g, <date></date>, etc...)"
              },
              "phone-number": {
                "label": "Phone Number"
              },
              "email": {
                "label": "Email",
                "placeholder": "Enter email (e.g. user@alphavork.com, etc...)"
              },
              "password": {
                "label": "Password",
                "placeholder": "Enter password (e.g. Aa1!Aa1!, etc...)"
              },
              "remember-me": {
                "label": "Remember me",
                "description": "Keeps you logged in on this device for 30 days."
              },
              "actions": {
                "submit": "Submit",
                "reset": "Reset"
              },
              "login": "Already have an account? <link>Login</link>",
              "terms-and-privacy": "By clicking, you agree to our <terms-of-service>Terms of Service</terms-of-service> and <privacy-policy>Privacy Policy</privacy-policy>.",
              "alerts": {
                "success": "Creating your Alphavork account was successfully succeeded",
                "error": "Something went wrong while creating your Alphavork account"
              }
            }
          }
        },
        "login": {
          "page": {
            "metadata": {
              "title": "Login"
            },
            "form": {
              "email": {
                "label": "Email",
                "placeholder": "Enter email (e.g. user@alphavork.com, etc...)"
              },
              "password": {
                "label": "Password",
                "placeholder": "Enter password (e.g. Aa1!Aa1!, etc...)",
                "forgot-password": "Forgot password?"
              },
              "remember-me": {
                "label": "Remember me",
                "description": "Keeps you logged in on this device for 30 days."
              },
              "actions": {
                "submit": "Submit",
                "reset": "Reset"
              },
              "create-new-account": "New on our platform? <link>Create new account</link>",
              "separator": "Or continue with",
              "alerts": {
                "success": "Logging to your Alphavork account was successfully succeeded",
                "error": "Something went wrong while logging to your Alphavork account"
              }
            }
          }
        },
        "reset-password": {
          "page": {
            "metadata": {
              "title": "Reset Password"
            },
            "forms": {
              "validate-email-form": {
                "title": "Forgot password?",
                "description": "No worries, we'll send you a code to reset your password.",
                "email": {
                  "label": "Email",
                  "placeholder": "Enter email (e.g. user@alphavork.com, etc...)"
                },
                "actions": {
                  "verify": "Verify"
                },
                "alerts": {
                  "error": "Something went wrong while verifying your email. Please try again."
                }
              }
            }
          }
        }
      }
    },
    "authentication": {
      "layout": {
        "metadata": {
          "title": {
            "default": "Authentication | Alphavork",
            "template": "%s | Alphavork Authentication"
          },
          "description": "Complete authentication flows including login, register, email verification, password reset, forgot password, and two-factor authentication."
        },
        "header": {
          "organization": "Alphavork"
        },
        "footer": {
          "copyrights": "2026 Alphavork. All rights reserved."
        }
