    "hooks": "@/features/components/hooks"
  },
  "registries": {
    "@coss": "https://coss.com/ui/r/{name}.json",
    "@magicui": "https://magicui.design/r/{name}",
    "@diceui": "https://diceui.com/r/{name}.json"
  }
